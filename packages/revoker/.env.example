ENVIRONMENT=prod

# Mezo RPC is used for current block and ERC165 token standard detection.
MEZO_RPC_URL=https://your-mezo-rpc.example

# Required for normal runs. Not required when running with -nodbrun.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional dev Supabase variables used when ENVIRONMENT is not prod.
SUPABASE_URL_DEV=https://your-dev-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY_DEV=your-dev-service-role-key

# Classic Blockscout API endpoint. Defaults to https://api.explorer.mezo.org/api.
REVOKER_BLOCKSCOUT_API_BASE_URL=https://api.explorer.mezo.org/api

# Mezo mainnet defaults to 31612.
REVOKER_CHAIN_ID=31612

# Scan tuning. Larger ranges reduce loop overhead but can hit Blockscout limits.
REVOKER_BLOCK_RANGE_SIZE=1000
REVOKER_REQUEST_COOLDOWN_MS=500
REVOKER_REQUEST_TIMEOUT_MS=20000
REVOKER_CONFIRMATION_BLOCKS=10
REVOKER_MAX_RANGES_PER_RUN=50
REVOKER_UPSERT_BATCH_SIZE=500
REVOKER_DEV_HISTORY_BLOCK_LIMIT=200000

# Docker entrypoint loop interval. 600 seconds = 10 minutes.
REVOKER_INTERVAL_SECONDS=600

# Checkpoint key in indexer_checkpoints.
REVOKER_INDEXER_NAME=revoker
